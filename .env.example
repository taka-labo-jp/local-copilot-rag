# GitHub Copilot モデル（CLI認証が自動で利用される）
COPILOT_MODEL=claude-sonnet-4.5

# アプリのリッスンアドレス
LISTEN_ADDR=0.0.0.0:8000

# 会話履歴DB
HISTORY_DB=data/history.db

# 一時アップロードディレクトリ
UPLOAD_DIR=uploads

PALACE_DIR=data/palace
BULK_UPLOAD_DIR=bulk_uploads

# 抽出した画像の保存先
EXTRACTED_IMAGE_DIR=uploads/extracted_images

# Tesseract OCR言語（例: jpn+eng）
OCR_LANG=jpn+eng

# 埋め込みモデル（セットアップ時に取得してローカル利用する）
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# true: 実行時はローカルキャッシュのみ参照（外部ダウンロードしない）
EMBEDDING_LOCAL_FILES_ONLY=true

# ランタイムの不要テレメトリ送信を抑止する（既定: true）
DISABLE_RUNTIME_TELEMETRY=true

# Excel表データを何行単位でチャンク化するか
EXCEL_TABLE_ROWS_PER_CHUNK=10

# LibreOffice経由のページOCR（図形/グラフ文字拾い）を有効化
ENABLE_VISUAL_PAGE_OCR=true

# ページOCRの最大ページ数（1ファイルあたり）
MAX_VISUAL_OCR_PAGES=30

# LibreOfficeコマンド
SOFFICE_BIN=soffice
